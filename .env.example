# ============================================================
# CoverMatch — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# --- PostgreSQL ---
# Connection string for your PostgreSQL instance
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/covermatch

# --- Better Auth ---
# Random secret (min 32 chars): openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_to_a_random_32_char_string

# --- Stripe ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID of the $9.99 Premium Report product
STRIPE_PREMIUM_REPORT_PRICE_ID=price_...

# --- Application ---
# Your production domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
