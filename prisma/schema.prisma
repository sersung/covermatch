generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js required models ───────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?    @map("email_verified")
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  savedQuotes   SavedQuote[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Insurance domain models ────────────────────────────────────────────────

model InsuranceSegment {
  id          String             @id @default(cuid())
  slug        String             @unique
  name        String
  description String?
  icon        String?
  active      Boolean            @default(true)
  plans       Plan[]
  dimensions  SegmentDimension[]
  savedQuotes SavedQuote[]

  @@map("insurance_segments")
}

model Provider {
  id               String   @id @default(cuid())
  name             String
  logoUrl          String?  @map("logo_url")
  affiliateLink    String?  @map("affiliate_link")
  affiliateNetwork String?  @map("affiliate_network")
  commissionType   String?  @map("commission_type")
  commissionValue  Decimal? @map("commission_value")
  cookieDays       Int?     @map("cookie_days")
  active           Boolean  @default(true)
  plans            Plan[]

  @@map("providers")
}

model Plan {
  id                  String             @id @default(cuid())
  providerId          String             @map("provider_id")
  segmentId           String             @map("segment_id")
  name                String
  monthlyPremiumUsd   Decimal?           @map("monthly_premium_usd")
  annualDeductibleUsd Decimal?           @map("annual_deductible_usd")
  reimbursementPct    Decimal?           @map("reimbursement_pct")
  coverageLimitUsd    Decimal?           @map("coverage_limit_usd")
  waitingPeriodDays   Int?               @map("waiting_period_days")
  highlights          String[]
  pros                String[]
  cons                String[]
  rating              Decimal?
  affiliateUrl        String?            @map("affiliate_url")
  lastUpdated         DateTime           @default(now()) @map("last_updated") @db.Date
  provider            Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  segment             InsuranceSegment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  planCoverageRules   PlanCoverageRule[]

  @@map("plans")
}

model SegmentDimension {
  id            String             @id @default(cuid())
  segmentId     String             @map("segment_id")
  dimensionType String             @map("dimension_type")
  slug          String
  label         String
  metadata      Json?
  segment       InsuranceSegment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  coverageRules PlanCoverageRule[]

  @@unique([segmentId, slug])
  @@map("segment_dimensions")
}

model PlanCoverageRule {
  id           String           @id @default(cuid())
  planId       String           @map("plan_id")
  dimensionId  String           @map("dimension_id")
  covers       Boolean          @default(true)
  surchargePct Decimal          @default(0) @map("surcharge_pct")
  notes        String?
  plan         Plan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  dimension    SegmentDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([planId, dimensionId])
  @@map("plan_coverage_rules")
}

model SavedQuote {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  segmentId       String           @map("segment_id")
  inputData       Json             @map("input_data")
  resultSnapshot  Json?            @map("result_snapshot")
  createdAt       DateTime         @default(now()) @map("created_at")
  label           String?
  isPaid          Boolean          @default(false) @map("is_paid")
  stripeSessionId String?          @map("stripe_session_id")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  segment         InsuranceSegment @relation(fields: [segmentId], references: [id])

  @@map("saved_quotes")
}
